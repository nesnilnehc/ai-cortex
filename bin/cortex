#!/bin/sh
# cortex — ai-cortex cross-IDE install & update manager
# POSIX sh, requires: git ln mkdir rm grep awk sed
set -eu

MARKER="<!-- generated by cortex -->"
LEGACY_RULE_NAMES="documentation-markdown-format standards-document-artifacts tools-list-dir-dotfiles"

# ---------------------------------------------------------------------------
# CORTEX_HOME resolution (3-tier)
# ---------------------------------------------------------------------------
_resolve_home() {
  if [ -n "${CORTEX_HOME:-}" ]; then
    printf '%s' "$CORTEX_HOME"
    return 0
  fi
  _sdir=$(cd "$(dirname "$0")" 2>/dev/null && pwd -P) || true
  _parent=$(dirname "${_sdir:-/nonexistent}")
  if [ -f "${_parent}/skills/INDEX.md" ] && [ -f "${_parent}/AGENTS.md" ]; then
    printf '%s' "$_parent"
    return 0
  fi
  printf '%s' "${XDG_DATA_HOME:-$HOME/.local/share}/ai-cortex"
}

CORTEX_HOME=$(_resolve_home)

# ---------------------------------------------------------------------------
# helpers
# ---------------------------------------------------------------------------
_ok()   { printf '  \033[32m✓\033[0m %s\n' "$*"; }
_warn() { printf '  \033[33m!\033[0m %s\n' "$*"; }
_err()  { printf '  \033[31m✗\033[0m %s\n' "$*" >&2; }
_info() { printf '  %s\n' "$*"; }
_hdr()  { printf '\n\033[1m%s\033[0m\n' "$*"; }

_confirm() {
  _msg="$1"
  printf '  %s [y/N] ' "$_msg"
  read -r _ans </dev/tty
  case "$_ans" in y|Y) return 0 ;; *) return 1 ;; esac
}

# ---------------------------------------------------------------------------
# frontmatter helpers (awk, no external yaml parser)
# ---------------------------------------------------------------------------
_frontmatter_field() {
  _file="$1"; _key="$2"
  awk -v key="$_key" '
    BEGIN { in_fm=0; found=0 }
    NR==1 && /^---$/ { in_fm=1; next }
    in_fm && /^---$/ { exit }
    in_fm {
      if (match($0, "^" key ":[ \t]*(.*)$")) {
        val = substr($0, RSTART + length(key) + 1)
        gsub(/^[ \t]+|[ \t]+$/, "", val)
        print val; found=1
      }
    }
  ' "$_file"
}

_rule_title() {
  _file="$1"
  awk '
    /^---$/ { fm++; next }
    fm >= 2 && /^# Rule:/ { sub(/^# Rule:[ \t]*/, ""); print; exit }
    fm >= 2 && /^# /      { sub(/^# /, ""); print; exit }
  ' "$_file"
}

# ---------------------------------------------------------------------------
# IDE detection
# ---------------------------------------------------------------------------
_has_claude() { [ -d "$HOME/.claude" ]; }
_has_cursor() { [ -d "$HOME/.cursor" ]; }

# ---------------------------------------------------------------------------
# symlink helpers
# ---------------------------------------------------------------------------
_link_skill() {
  _src="$1"; _dst="$2"; _skill=$(basename "$_src")
  if [ -e "$_dst" ] && [ ! -L "$_dst" ]; then
    _warn "skip $_skill: real directory exists at $_dst"
    return 0
  fi
  if [ -L "$_dst" ]; then
    _cur=$(readlink "$_dst" 2>/dev/null || true)
    if [ "$_cur" != "$_src" ] && ! echo "$_cur" | grep -q "$CORTEX_HOME"; then
      _warn "skip $_skill: non-cortex symlink at $_dst -> $_cur"
      return 0
    fi
  fi
  ln -sfn "$_src" "$_dst"
  _ok "linked skill $_skill"
}

_link_rule_md() {
  _src="$1"; _dst="$2"; _base=$(basename "$_src")
  if [ -e "$_dst" ] && [ ! -L "$_dst" ]; then
    _warn "skip rule $_base: real file at $_dst"
    return 0
  fi
  ln -sfn "$_src" "$_dst"
  _ok "linked rule $_base"
}

# ---------------------------------------------------------------------------
# .md -> .mdc translation for Cursor
# ---------------------------------------------------------------------------
_translate_rule() {
  _src="$1"; _dst="$2"
  _base=$(basename "$_src")

  _scope=$(_frontmatter_field "$_src" "recommended_scope")
  _desc=$(_frontmatter_field "$_src" "description")
  if [ -z "$_desc" ]; then
    _desc=$(_rule_title "$_src")
  fi
  if [ -z "$_desc" ]; then
    _warn "skip $_base: no description or H1 title found"
    return 1
  fi
  if [ -z "$_scope" ]; then
    _warn "skip $_base: missing recommended_scope"
    return 1
  fi

  case "$_scope" in
    user|both) _always=true  ;;
    *)         _always=false ;;
  esac

  _body=$(awk 'BEGIN{n=0} /^---$/{n++; if(n==2){p=1}; next} p{print}' "$_src")

  printf '%s\n---\ndescription: %s\nglobs: ["**/*"]\nalwaysApply: %s\n---\n%s\n' \
    "$MARKER" "$_desc" "$_always" "$_body" > "$_dst"
  _ok "translated rule $(basename "$_src" .md).mdc"
}

# ---------------------------------------------------------------------------
# _sync: push skills + rules to all detected IDEs
# ---------------------------------------------------------------------------
_sync() {
  _hdr "Syncing skills and rules..."

  _info "Codex-compatible agents skills path"
  mkdir -p "$HOME/.agents/skills"
  for _skill_dir in "$CORTEX_HOME/skills"/*/; do
    if [ -d "$_skill_dir" ]; then
      _name=$(basename "$_skill_dir")
      _link_skill "$_skill_dir" "$HOME/.agents/skills/$_name"
    fi
  done

  if _has_claude; then
    _info "Claude Code detected"
    mkdir -p "$HOME/.claude/skills" "$HOME/.claude/rules"
    for _skill_dir in "$CORTEX_HOME/skills"/*/; do
      if [ -d "$_skill_dir" ]; then
        _name=$(basename "$_skill_dir")
        _link_skill "$_skill_dir" "$HOME/.claude/skills/$_name"
      fi
    done
    for _rule in "$CORTEX_HOME/rules"/*.md; do
      if [ -e "$_rule" ]; then
        _rbase=$(basename "$_rule")
        if [ "$_rbase" = "INDEX.md" ]; then continue; fi
        _link_rule_md "$_rule" "$HOME/.claude/rules/$_rbase"
      fi
    done
  fi

  if _has_cursor; then
    _info "Cursor detected"
    mkdir -p "$HOME/.cursor/skills" "$HOME/.cursor/rules"
    for _skill_dir in "$CORTEX_HOME/skills"/*/; do
      if [ -d "$_skill_dir" ]; then
        _name=$(basename "$_skill_dir")
        _link_skill "$_skill_dir" "$HOME/.cursor/skills/$_name"
      fi
    done
    for _rule in "$CORTEX_HOME/rules"/*.md; do
      if [ -e "$_rule" ]; then
        _rbase=$(basename "$_rule")
        if [ "$_rbase" = "INDEX.md" ]; then continue; fi
        _mdc="$HOME/.cursor/rules/$(basename "$_rule" .md).mdc"
        _translate_rule "$_rule" "$_mdc" || true
      fi
    done
  fi

  if ! _has_claude && ! _has_cursor; then
    _warn "No Claude Code or Cursor install detected; synced ~/.agents/skills for Codex-compatible skill discovery"
  fi
}

# ---------------------------------------------------------------------------
# prune cortex-owned broken symlinks after update
# ---------------------------------------------------------------------------
_prune_stale() {
  for _ide_skills in "$HOME/.agents/skills" "$HOME/.claude/skills" "$HOME/.cursor/skills"; do
    if [ ! -d "$_ide_skills" ]; then continue; fi
    for _link in "$_ide_skills"/*; do
      if [ -L "$_link" ] && [ ! -e "$_link" ]; then
        _target=$(readlink "$_link" 2>/dev/null || true)
        if echo "$_target" | grep -q "$CORTEX_HOME"; then
          rm "$_link"
          _ok "pruned stale symlink $(basename "$_link")"
        fi
      fi
    done
  done

  for _ide_rules in "$HOME/.claude/rules" "$HOME/.cursor/rules"; do
    if [ ! -d "$_ide_rules" ]; then continue; fi
    for _link in "$_ide_rules"/*; do
      if [ -L "$_link" ] && [ ! -e "$_link" ]; then
        _target=$(readlink "$_link" 2>/dev/null || true)
        if echo "$_target" | grep -q "$CORTEX_HOME"; then
          rm "$_link"
          _ok "pruned stale symlink $(basename "$_link")"
        fi
      fi
    done
  done

  _cursor_rules="$HOME/.cursor/rules"
  if [ -d "$_cursor_rules" ]; then
    for _mdc in "$_cursor_rules"/*.mdc; do
      if [ ! -e "$_mdc" ]; then continue; fi
      if grep -q "$MARKER" "$_mdc" 2>/dev/null; then
        _stem=$(basename "$_mdc" .mdc)
        if [ ! -f "$CORTEX_HOME/rules/${_stem}.md" ]; then
          rm "$_mdc"
          _ok "pruned stale .mdc ${_stem}.mdc"
        fi
      fi
    done
  fi
}

# ---------------------------------------------------------------------------
# legacy detection
# ---------------------------------------------------------------------------
_detect_legacy() {
  _LEGACY_FOUND=0

  # A: old whole-repo clones
  for _path in "$HOME/.claude/skills/ai-cortex" "$HOME/.cursor/skills/ai-cortex"; do
    if [ -e "$_path" ]; then
      _warn "[A] old whole-repo clone: $_path"
      _LEGACY_FOUND=1
    fi
  done

  # B: broken symlinks in skill/rule target dirs
  for _dir in "$HOME/.agents/skills" "$HOME/.claude/skills" "$HOME/.cursor/skills" "$HOME/.claude/rules" "$HOME/.cursor/rules"; do
    if [ ! -d "$_dir" ]; then continue; fi
    for _link in "$_dir"/*; do
      if [ -L "$_link" ] && [ ! -e "$_link" ]; then
        _warn "[B] broken symlink: $_link"
        _LEGACY_FOUND=1
      fi
    done
  done

  # C: Vercel CLI symlinks (target contains /.agents/skills/)
  _vercel_count=0
  if [ -d "$HOME/.claude/skills" ]; then
    for _link in "$HOME/.claude/skills"/*; do
      if [ -L "$_link" ]; then
        _t=$(readlink "$_link" 2>/dev/null || true)
        if echo "$_t" | grep -q "/.agents/skills/"; then
          _vercel_count=$((_vercel_count + 1))
        fi
      fi
    done
  fi
  if [ "$_vercel_count" -gt 0 ]; then
    _warn "[C] $_vercel_count Vercel CLI symlinks in ~/.claude/skills/ (default: kept, ask to switch)"
    _LEGACY_FOUND=1
  fi

  # D: drifted .mdc (name matches current rule but no cortex marker)
  if [ -d "$HOME/.cursor/rules" ]; then
    for _rule in "$CORTEX_HOME/rules"/*.md; do
      if [ ! -e "$_rule" ]; then continue; fi
      _stem=$(basename "$_rule" .md)
      _mdc="$HOME/.cursor/rules/${_stem}.mdc"
      if [ -f "$_mdc" ] && ! grep -q "$MARKER" "$_mdc" 2>/dev/null; then
        _warn "[D] drifted .mdc (not cortex-generated): $_mdc"
        _LEGACY_FOUND=1
      fi
    done
  fi

  # D': orphan .mdc from known legacy rule names
  if [ -d "$HOME/.cursor/rules" ]; then
    for _name in $LEGACY_RULE_NAMES; do
      _mdc="$HOME/.cursor/rules/${_name}.mdc"
      if [ -f "$_mdc" ]; then
        _warn "[D'] orphan legacy .mdc: $_mdc"
        _LEGACY_FOUND=1
      fi
    done
  fi

  # E: project-local .cursor/rules/ in cortex repo working tree
  if [ -f "$PWD/bin/cortex" ] && [ -f "$PWD/AGENTS.md" ] && [ -f "$PWD/skills/INDEX.md" ]; then
    if [ -d "$PWD/.cursor/rules" ]; then
      _warn "[E] project-local .cursor/rules/ in cortex working tree (not cleaned)"
      _LEGACY_FOUND=1
    fi
  fi

  # F: deprecated artifact files
  for _dep in "$HOME/.claude/skills/ai-cortex/manifest.json" \
               "$HOME/.claude/skills/ai-cortex/agent.yaml" \
               "$HOME/.cursor/skills/ai-cortex/manifest.json" \
               "$HOME/.cursor/skills/ai-cortex/agent.yaml"; do
    if [ -e "$_dep" ]; then
      _warn "[F] deprecated artifact: $_dep"
      _LEGACY_FOUND=1
    fi
  done
}

# ---------------------------------------------------------------------------
# cmd_install
# ---------------------------------------------------------------------------
cmd_install() {
  _hdr "cortex install"

  _detect_legacy
  if [ "$_LEGACY_FOUND" -ne 0 ]; then
    _warn "Legacy artifacts detected. Run 'cortex clean --dry-run' to review, then 'cortex clean' to remove."
    printf '\n'
  fi

  if [ ! -d "$CORTEX_HOME" ]; then
    _info "Cloning ai-cortex to $CORTEX_HOME..."
    mkdir -p "$(dirname "$CORTEX_HOME")"
    git clone --depth 1 https://github.com/nesnilnehc/ai-cortex.git "$CORTEX_HOME"
  else
    _info "CORTEX_HOME already exists: $CORTEX_HOME"
  fi

  _sync

  # suggest adding to PATH if not already there
  _local_bin="$HOME/.local/bin/cortex"
  if [ ! -e "$_local_bin" ]; then
    if echo ":${PATH}:" | grep -q ":$HOME/.local/bin:"; then
      printf '\n'
      _info "Tip: add cortex to PATH with:"
      _info "  ln -s $CORTEX_HOME/bin/cortex $HOME/.local/bin/cortex"
    fi
  fi

  printf '\n'
  _ok "Install complete. Run 'cortex status' to verify."
}

# ---------------------------------------------------------------------------
# cmd_update
# ---------------------------------------------------------------------------
cmd_update() {
  _force=0
  for _arg in "$@"; do
    if [ "$_arg" = "--force" ]; then _force=1; fi
  done

  _hdr "cortex update"

  if [ ! -d "$CORTEX_HOME/.git" ]; then
    _err "CORTEX_HOME is not a git repository: $CORTEX_HOME"
    exit 1
  fi

  _dirty=$(git -C "$CORTEX_HOME" status --porcelain 2>/dev/null || true)
  if [ -n "$_dirty" ]; then
    if [ "$_force" -eq 0 ]; then
      _err "Working tree dirty. Use --force to override."
      exit 1
    fi
    _warn "Working tree dirty, proceeding with --force"
  fi

  _branch=$(git -C "$CORTEX_HOME" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null \
    | sed 's@^refs/remotes/origin/@@' || echo "main")
  _info "Fetching origin/$_branch..."
  git -C "$CORTEX_HOME" fetch origin
  git -C "$CORTEX_HOME" reset --hard "origin/$_branch"

  _prune_stale
  _sync

  printf '\n'
  _ok "Update complete."
}

# ---------------------------------------------------------------------------
# cmd_clean
# ---------------------------------------------------------------------------
cmd_clean() {
  _dry=0; _yes=0
  for _arg in "$@"; do
    case "$_arg" in
      --dry-run) _dry=1 ;;
      --yes)     _yes=1 ;;
    esac
  done

  _hdr "cortex clean"
  if [ "$_dry" -eq 1 ]; then _info "(dry-run — no changes will be made)"; fi

  _clean_found=0

  # A: old whole-repo clones
  for _path in "$HOME/.claude/skills/ai-cortex" "$HOME/.cursor/skills/ai-cortex"; do
    if [ ! -e "$_path" ]; then continue; fi
    _clean_found=1
    _info "[A] Found old whole-repo clone: $_path"
    if [ "$_dry" -eq 1 ]; then continue; fi
    _do=0
    if [ "$_yes" -eq 1 ]; then _do=1; else _confirm "Remove $_path?" && _do=1 || true; fi
    if [ "$_do" -eq 1 ]; then rm -rf "$_path"; _ok "Removed $_path"; fi
  done

  # B: broken symlinks
  for _dir in "$HOME/.agents/skills" "$HOME/.claude/skills" "$HOME/.cursor/skills" "$HOME/.claude/rules" "$HOME/.cursor/rules"; do
    if [ ! -d "$_dir" ]; then continue; fi
    for _link in "$_dir"/*; do
      if [ -L "$_link" ] && [ ! -e "$_link" ]; then
        _clean_found=1
        _info "[B] Broken symlink: $_link"
        if [ "$_dry" -eq 1 ]; then continue; fi
        _do=0
        if [ "$_yes" -eq 1 ]; then _do=1; else _confirm "Remove $_link?" && _do=1 || true; fi
        if [ "$_do" -eq 1 ]; then rm "$_link"; _ok "Removed $_link"; fi
      fi
    done
  done

  # C: Vercel CLI symlinks — ask before switching
  if [ -d "$HOME/.claude/skills" ]; then
    _vlinks=""
    for _link in "$HOME/.claude/skills"/*; do
      if [ -L "$_link" ]; then
        _t=$(readlink "$_link" 2>/dev/null || true)
        if echo "$_t" | grep -q "/.agents/skills/"; then
          _vlinks="$_vlinks $_link"
        fi
      fi
    done
    if [ -n "$_vlinks" ]; then
      _clean_found=1
      _count=$(echo "$_vlinks" | wc -w | tr -d ' ')
      _info "[C] Found $_count Vercel CLI symlinks in ~/.claude/skills/"
      _info "These are kept by default. Remove to let cortex manage instead?"
      if [ "$_dry" -eq 0 ]; then
        _do=0
        if [ "$_yes" -eq 1 ]; then _do=1; else _confirm "Switch $_count Vercel CLI links to cortex?" && _do=1 || true; fi
        if [ "$_do" -eq 1 ]; then
          for _link in $_vlinks; do rm "$_link"; _ok "Removed Vercel symlink $(basename "$_link")"; done
        fi
      fi
    fi
  fi

  # E: real directories in ~/.agents/skills/ shadowing cortex-managed skills
  if [ -d "$HOME/.agents/skills" ]; then
    _real_dirs=""
    for _skill_dir in "$CORTEX_HOME/skills"/*/; do
      _name=$(basename "$_skill_dir")
      _dst="$HOME/.agents/skills/$_name"
      if [ -e "$_dst" ] && [ ! -L "$_dst" ]; then
        _real_dirs="$_real_dirs $_dst"
      fi
    done
    if [ -n "$_real_dirs" ]; then
      _clean_found=1
      _count=$(echo "$_real_dirs" | wc -w | tr -d ' ')
      _info "[E] Found $_count real directories in ~/.agents/skills/ shadowing cortex skills"
      _info "These block cortex from managing symlinks. Replace with cortex-managed symlinks?"
      if [ "$_dry" -eq 0 ]; then
        _do=0
        if [ "$_yes" -eq 1 ]; then _do=1; else _confirm "Replace $_count real dirs with cortex symlinks?" && _do=1 || true; fi
        if [ "$_do" -eq 1 ]; then
          for _dst in $_real_dirs; do
            _name=$(basename "$_dst")
            rm -rf "$_dst"
            ln -sfn "$CORTEX_HOME/skills/$_name" "$_dst"
            _ok "Replaced real dir with symlink: $_name"
          done
        fi
      fi
    fi
  fi

  # D: drifted .mdc
  if [ -d "$HOME/.cursor/rules" ]; then
    for _rule in "$CORTEX_HOME/rules"/*.md; do
      if [ ! -e "$_rule" ]; then continue; fi
      _stem=$(basename "$_rule" .md)
      _mdc="$HOME/.cursor/rules/${_stem}.mdc"
      if [ -f "$_mdc" ] && ! grep -q "$MARKER" "$_mdc" 2>/dev/null; then
        _clean_found=1
        _info "[D] Drifted .mdc (not cortex-generated): $_mdc"
        if [ "$_dry" -eq 1 ]; then continue; fi
        _do=0
        if [ "$_yes" -eq 1 ]; then _do=1; else _confirm "Remove drifted $_mdc?" && _do=1 || true; fi
        if [ "$_do" -eq 1 ]; then rm "$_mdc"; _ok "Removed $_mdc"; fi
      fi
    done
  fi

  # D': orphan legacy .mdc
  if [ -d "$HOME/.cursor/rules" ]; then
    for _name in $LEGACY_RULE_NAMES; do
      _mdc="$HOME/.cursor/rules/${_name}.mdc"
      if [ -f "$_mdc" ]; then
        _clean_found=1
        _info "[D'] Orphan legacy .mdc: $_mdc"
        if [ "$_dry" -eq 1 ]; then continue; fi
        _do=0
        if [ "$_yes" -eq 1 ]; then _do=1; else _confirm "Remove orphan $_mdc?" && _do=1 || true; fi
        if [ "$_do" -eq 1 ]; then rm "$_mdc"; _ok "Removed $_mdc"; fi
      fi
    done
  fi

  printf '\n'
  if [ "$_clean_found" -eq 0 ]; then
    _ok "No legacy artifacts found."
  elif [ "$_dry" -eq 1 ]; then
    _info "Dry-run complete. Run 'cortex clean' (without --dry-run) to apply."
  else
    _ok "Clean complete."
  fi
}

# ---------------------------------------------------------------------------
# cmd_status
# ---------------------------------------------------------------------------
cmd_status() {
  _hdr "cortex status"

  _info "CORTEX_HOME: $CORTEX_HOME"

  if [ -d "$CORTEX_HOME/.git" ]; then
    _commit=$(git -C "$CORTEX_HOME" rev-parse --short HEAD 2>/dev/null || echo "unknown")
    _info "Commit: $_commit"
  else
    _warn "CORTEX_HOME is not a git repository"
  fi

  printf '\n'
  _info "Detected IDEs:"
  _info "  Codex-compatible agents path (~/.agents/skills)"
  if _has_claude; then _info "  Claude Code (~/.claude)"; else _info "  Claude Code: not detected"; fi
  if _has_cursor; then _info "  Cursor (~/.cursor)"; else _info "  Cursor: not detected"; fi

  printf '\n'
  _info "Skills:"
  _skill_count=0
  for _s in "$CORTEX_HOME/skills"/*/; do
    if [ -d "$_s" ]; then _skill_count=$((_skill_count + 1)); fi
  done
  _info "  Source: $_skill_count skills in CORTEX_HOME/skills/"

  _present=0
  _linked=0
  for _s in "$CORTEX_HOME/skills"/*/; do
    if [ -d "$_s" ]; then
      _n=$(basename "$_s")
      if [ -e "$HOME/.agents/skills/$_n" ]; then _present=$((_present + 1)); fi
      if [ -L "$HOME/.agents/skills/$_n" ]; then _linked=$((_linked + 1)); fi
    fi
  done
  _info "  Codex-compatible ~/.agents/skills: $_present/$_skill_count present ($_linked symlinked)"

  if _has_claude; then
    _linked=0
    for _s in "$CORTEX_HOME/skills"/*/; do
      if [ -d "$_s" ]; then
        _n=$(basename "$_s")
        if [ -L "$HOME/.claude/skills/$_n" ]; then _linked=$((_linked + 1)); fi
      fi
    done
    _info "  Claude Code: $_linked/$_skill_count linked"
  fi

  if _has_cursor; then
    _linked=0
    for _s in "$CORTEX_HOME/skills"/*/; do
      if [ -d "$_s" ]; then
        _n=$(basename "$_s")
        if [ -L "$HOME/.cursor/skills/$_n" ]; then _linked=$((_linked + 1)); fi
      fi
    done
    _info "  Cursor: $_linked/$_skill_count linked"
  fi

  printf '\n'
  _info "Rules:"
  _rule_count=0
  for _r in "$CORTEX_HOME/rules"/*.md; do
    if [ -e "$_r" ] && [ "$(basename "$_r")" != "INDEX.md" ]; then
      _rule_count=$((_rule_count + 1))
    fi
  done
  _info "  Source: $_rule_count rules in CORTEX_HOME/rules/"

  if _has_claude; then
    _linked=0
    for _r in "$CORTEX_HOME/rules"/*.md; do
      if [ -e "$_r" ] && [ "$(basename "$_r")" != "INDEX.md" ]; then
        if [ -L "$HOME/.claude/rules/$(basename "$_r")" ]; then _linked=$((_linked + 1)); fi
      fi
    done
    _info "  Claude Code: $_linked/$_rule_count .md symlinked"
  fi

  if _has_cursor; then
    _synced=0
    for _r in "$CORTEX_HOME/rules"/*.md; do
      if [ -e "$_r" ] && [ "$(basename "$_r")" != "INDEX.md" ]; then
        _mdc="$HOME/.cursor/rules/$(basename "$_r" .md).mdc"
        if [ -f "$_mdc" ] && grep -q "$MARKER" "$_mdc" 2>/dev/null; then
          _synced=$((_synced + 1))
        fi
      fi
    done
    _info "  Cursor: $_synced/$_rule_count .mdc generated"
  fi

  printf '\n'
  _info "Asset paths (for Agent direct access):"
  _info "  specs:     $CORTEX_HOME/specs/"
  _info "  protocols: $CORTEX_HOME/protocols/"

  printf '\n'
  _detect_legacy
  if [ "$_LEGACY_FOUND" -ne 0 ]; then
    _warn "Legacy artifacts detected. Run 'cortex clean --dry-run' to review."
  else
    _ok "No legacy artifacts detected."
  fi
}

# ---------------------------------------------------------------------------
# cmd_uninstall
# ---------------------------------------------------------------------------
cmd_uninstall() {
  _yes=0
  _remove_home=0
  for _arg in "$@"; do
    case "$_arg" in
      --yes)         _yes=1 ;;
      --remove-home) _remove_home=1 ;;
    esac
  done

  _hdr "cortex uninstall"
  _info "Removing cortex-managed symlinks and generated files..."

  # Remove cortex-owned skill symlinks
  for _dir in "$HOME/.agents/skills" "$HOME/.claude/skills" "$HOME/.cursor/skills"; do
    if [ ! -d "$_dir" ]; then continue; fi
    for _link in "$_dir"/*; do
      if [ -L "$_link" ]; then
        _t=$(readlink "$_link" 2>/dev/null || true)
        if echo "$_t" | grep -q "$CORTEX_HOME"; then
          rm "$_link"
          _ok "Removed symlink $(basename "$_link") from $(basename "$_dir")"
        fi
      fi
    done
  done

  # Remove cortex-owned rule symlinks
  for _dir in "$HOME/.claude/rules" "$HOME/.cursor/rules"; do
    if [ ! -d "$_dir" ]; then continue; fi
    for _link in "$_dir"/*.md; do
      if [ -L "$_link" ]; then
        _t=$(readlink "$_link" 2>/dev/null || true)
        if echo "$_t" | grep -q "$CORTEX_HOME"; then
          rm "$_link"
          _ok "Removed rule symlink $(basename "$_link")"
        fi
      fi
    done
  done

  # Remove cortex-generated .mdc files
  if [ -d "$HOME/.cursor/rules" ]; then
    for _mdc in "$HOME/.cursor/rules"/*.mdc; do
      if [ ! -e "$_mdc" ]; then continue; fi
      if grep -q "$MARKER" "$_mdc" 2>/dev/null; then
        rm "$_mdc"
        _ok "Removed generated $(basename "$_mdc")"
      fi
    done
  fi

  printf '\n'
  _ok "Cortex-managed files removed."

  # CORTEX_HOME removal: always requires explicit --remove-home flag
  # --yes alone does NOT auto-confirm this — it would delete the repo
  if [ "$_remove_home" -eq 1 ]; then
    _info "CORTEX_HOME: $CORTEX_HOME"
    _do=0
    if [ "$_yes" -eq 1 ]; then
      _do=1
    else
      _confirm "Also remove CORTEX_HOME ($CORTEX_HOME)?" && _do=1 || true
    fi
    if [ "$_do" -eq 1 ]; then
      rm -rf "$CORTEX_HOME"
      _ok "Removed $CORTEX_HOME"
    fi
  else
    _info "CORTEX_HOME preserved: $CORTEX_HOME"
    _info "To also remove it, run: cortex uninstall --remove-home"
  fi
}

# ---------------------------------------------------------------------------
# main dispatch
# ---------------------------------------------------------------------------
_usage() {
  cat <<'EOF'

Usage: cortex <command> [options]

Commands:
  install          Install ai-cortex to all detected IDEs
  update           Fetch latest and re-sync (--force to override dirty tree)
  clean            Remove legacy artifacts (--dry-run, --yes)
  status           Show installation status (read-only)
  uninstall        Remove cortex-managed files (--remove-home to also delete CORTEX_HOME)

Options for uninstall:
  --yes            Skip confirmation for symlink/file removal
  --remove-home    Also remove CORTEX_HOME directory (requires explicit flag)

EOF
}

if [ $# -eq 0 ]; then
  _usage
  exit 1
fi

_cmd="$1"; shift
case "$_cmd" in
  install)   cmd_install "$@" ;;
  update)    cmd_update "$@" ;;
  clean)     cmd_clean "$@" ;;
  status)    cmd_status "$@" ;;
  uninstall) cmd_uninstall "$@" ;;
  *)
    _err "Unknown command: $_cmd"
    _usage
    exit 1
    ;;
esac
